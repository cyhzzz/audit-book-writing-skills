# API Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model Configuration
DEFAULT_MODEL=glm-4.7
FALLBACK_MODEL=glm-4.6
MODEL_TEMPERATURE=0.3
MAX_TOKENS=4000

# File Path Configuration
OUTPUT_DIR=./output
TEMP_DIR=./temp
LOG_DIR=./logs

# Case Source Websites
NCHA_URL=http://www.ncha.gov.cn
ZJWWJ_URL=http://wwj.zj.gov.cn

# Skill Configuration
MAX_FILE_SIZE=52428800  # 50MB in bytes
DEFAULT_MIN_WORD_COUNT=5000

# Marking Rules
ENABLE_FA1=true
ENABLE_FA2=true
ENABLE_FB1=true
ENABLE_FB2=true
ENABLE_FC1=true
ENABLE_FC2=true
ENABLE_A1=true
ENABLE_A2=true

# Verification Rules
MAX_REGULATION_FILES=8
SIMILARITY_THRESHOLD=0.7
STRICT_MODE=true

# Case Replacement Rules
MAX_SEARCH_RESULTS=5
ALLOW_CASE_DELETION=true

# Content Expansion Rules
MAX_EXPANSION_PER_REGULATION=3
INCLUDE_AUDIT_APPLICATION=true
INCLUDE_SOURCE_URL=true
FORBID_OFF_TOPIC=true
FORBID_FINANCIAL_CONTENT=true

# Structure Optimization Rules
MERGE_DUPLICATE_CONTENT=true
RESOLVE_CONFLICTS=true
PRESERVE_STRUCTURE=true

# Output Configuration
GENERATE_PDF_REPORT=true
GENERATE_JSON_REPORTS=true
GENERATE_EXECUTION_LOG=true
